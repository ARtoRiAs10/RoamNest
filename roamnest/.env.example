# Copy this file to .env and fill in your actual values

# MongoDB Atlas connection string
ATLASDB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wanderlust?retryWrites=true&w=majority

# Session secret key (use a long random string)
SECRET=your_super_secret_session_key_here_change_this

# Cloudinary credentials (for image uploads)
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# Node environment
NODE_ENV=development
