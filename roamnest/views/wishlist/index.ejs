<% layout("/layouts/boilerplate") %>

<style>
  .wishlist-header {
    background: linear-gradient(135deg, #6C63FF, #3ECFCF);
    color: white;
    padding: 2rem;
    border-radius: 16px;
    margin-bottom: 2rem;
    text-align: center;
  }
  .listing-card {
    border: none;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .listing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }
  .listing-card img {
    height: 200px;
    object-fit: cover;
  }
  .price-badge {
    background: linear-gradient(135deg, #6C63FF, #3ECFCF);
    color: white;
    padding: 4px 10px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.85rem;
  }
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
  }
  .empty-state i {
    font-size: 5rem;
    color: #ddd;
    margin-bottom: 1rem;
  }
  .remove-btn {
    background: none;
    border: none;
    color: #6C63FF;
    font-size: 1.1rem;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .remove-btn:hover {
    transform: scale(1.2);
  }
</style>

<div class="container mt-4">
  <div class="wishlist-header">
    <h2><i class="fa-solid fa-heart me-2"></i> My Wishlist</h2>
    <p class="mb-0 opacity-75">Your saved dream destinations</p>
  </div>

  <% if (listings.length === 0) { %>
    <div class="empty-state">
      <i class="fa-regular fa-heart"></i>
      <h4 class="text-muted">Your wishlist is empty</h4>
      <p class="text-muted">Save listings by clicking the ❤️ button on any listing page.</p>
      <a href="/listings" class="btn btn-danger mt-2">
        <i class="fa-solid fa-compass me-1"></i> Browse Listings
      </a>
    </div>
  <% } else { %>
    <p class="text-muted mb-3"><%= listings.length %> saved listing<%= listings.length > 1 ? 's' : '' %></p>
    <div class="row">
      <% for (let listing of listings) { %>
        <div class="col-md-4 col-sm-6 mb-4">
          <div class="listing-card card h-100">
            <a href="/listings/<%= listing._id %>" style="text-decoration:none; color: inherit;">
              <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" />
              <div class="card-body">
                <h6 class="card-title fw-bold"><%= listing.title %></h6>
                <p class="text-muted mb-1"><i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %></p>
                <span class="price-badge">₹<%= listing.price.toLocaleString("en-IN") %>/night</span>
              </div>
            </a>
            <div class="card-footer d-flex justify-content-between align-items-center bg-white border-top-0">
              <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-outline-dark">View Details</a>
              <form method="POST" action="/wishlist/<%= listing._id %>">
                <button class="remove-btn" title="Remove from wishlist">
                  <i class="fa-solid fa-heart"></i> Remove
                </button>
              </form>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
